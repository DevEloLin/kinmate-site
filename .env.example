# KinMate marketing 站环境变量样板。复制为 .env.local 后填写真实值。
#
# 上线前需配置；未配置时下载按钮回退为 disabled，
# 不会发生空 href="#" 跳无效页（见 lib/store-links.ts）。

# iOS App Store URL（如 https://apps.apple.com/cn/app/kinmate/idXXXXXXXXXX）
NEXT_PUBLIC_APP_STORE_URL=

# Google Play URL（如 https://play.google.com/store/apps/details?id=app.kinmate）
NEXT_PUBLIC_GOOGLE_PLAY_URL=
